<div class="container">
    <div class="row justify-content-center pt-5">
        <div class="col-4">
            <div class="card">
                <div class="card-body">
                    <h6 class="text-uppercase text-center mb-4 mt-3">Connexion</h6>
                    <center>
                        <% if (message) { %>
                            <span class="text-danger"><%- message %><br><br></span>
                        <% } %>

                        <form style="padding-left: 30px; padding-right: 30px; margin-bottom: 10px;" action="/auth/login" method="post">
                            <div class="form-group">
                                <input class="form-control" type="email" name="email">
                            </div>
                            <div class="form-group mt-2">
                                <input class="form-control" type="password" name="password">
                            </div>
                            <div class="form-group mt-2">
                                <input class="form-control" type="submit">
                            </div>
                        </form>
                    </center>
                </div>
            </div>
        </div>
    </div>
</div>